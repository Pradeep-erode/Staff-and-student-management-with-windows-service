<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <add key="StartTime" value="07:15 PM" />
    <add key="callDuration" value="2" />
    <add key="CallType" value="1" />
    <add key="FromMail" value="--from mail--" />
    <add key="Password" value="--from password--" />
    <add key="Host" value="smtp.gmail.com" />
  </appSettings>
  <system.net>
    <mailSettings>
      <smtp from="--from mail--">
        <network host="smtp.gmail.com" userName="--from mail--" password="--from password--" enableSsl="true" port="587" />
      </smtp>
    </mailSettings>
  </system.net>
<!--<connectionStrings>
		<add name="constr" connectionString="--db connection string--"/>
	</connectionStrings>
	</configuration>-->
<connectionStrings><add name="StaffmanagementEntitiesss" connectionString="--db connection string--" /></connectionStrings>
</configuration>
